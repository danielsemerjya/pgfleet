# Managed by Ansible (db_stack role). Secrets from vault.
[global]
repo1-type        = s3
repo1-path        = /repo
repo1-s3-bucket   = {{ backup_s3_bucket }}
repo1-s3-endpoint = {{ backup_s3_endpoint }}
repo1-s3-region   = {{ backup_s3_region }}
repo1-s3-key      = {{ vault_ovh_aws_access_key }}
repo1-s3-key-secret = {{ vault_ovh_aws_secret_key }}

repo1-cipher-type = aes-256-cbc
repo1-cipher-pass = {{ vault_backup_cipher_pass }}

repo1-retention-full = {{ backup_retention_full }}
repo1-retention-diff = {{ backup_retention_diff }}

archive-async = y
spool-path    = /var/spool/pgbackrest
process-max   = 2
compress-type = zst
start-fast    = y
log-level-console = info
log-level-file    = detail
log-path = /var/log/pgbackrest

[main]
pg1-path = /var/lib/postgresql/data
